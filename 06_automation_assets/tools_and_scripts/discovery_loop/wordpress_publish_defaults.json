{
  "wordpress_endpoint": "https://www.sourovdeb.com/wp-json/sourov/v1/ai-post",
  "deploy_gateway_url": "https://www.sourovdeb.com/deploy.php",
  "deploy_gateway_key_env": "DEPLOY_GATEWAY_KEY",
  "default_status": "future",
  "schedule_midnight": true,
  "schedule_timezone": "UTC",
  "default_tags": [
    "automation",
    "wordpress",
    "drafts"
  ],
  "default_categories": [
    "automation-updates"
  ],
  "hourly_story_default_status": "future",
  "hourly_story_default_tags": [
    "chronological-story",
    "sourov"
  ],
  "hourly_story_default_categories": [
    "life-story"
  ],
  "hourly_story_output_dir": "03_communications/hourly_story_posts",
  "hourly_story_source_globs": [
    "02_identity_profile/**/*.md",
    "03_communications/**/*.md",
    "04_legal_medical/**/*.md",
    "05_jobs_cv_outreach/**/*.md",
    "07_mental_health_support/**/*.md"
  ],
  "draft_paths": [
    "IMPORTANT_FOR_USER.md"
  ],
  "security_note": "Do not commit API keys, FTP passwords, or deploy gateway secrets."
}
