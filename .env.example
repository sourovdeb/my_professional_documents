# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# WordPress / Deploy gateway
DEPLOY_URL=https://www.sourovdeb.com/deploy.php
DEPLOY_KEY=your_secret_key_here

# WordPress REST API (alternative to deploy.php)
# Create an Application Password: WP Admin → Users → Profile → Application Passwords
WP_URL=https://www.sourovdeb.com
WP_USER=your_wordpress_username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Job search (optional API keys — all scripts work without them via free scraping)
RAPIDAPI_KEY=optional_for_enhanced_indeed_access

# Email (if using Gmail automation)
GMAIL_CREDENTIALS_FILE=path/to/gmail_credentials.json
