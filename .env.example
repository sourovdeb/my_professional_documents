# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# WordPress / Deploy gateway (already set up on your server)
DEPLOY_URL=https://www.sourovdeb.com/deploy.php
DEPLOY_KEY=your_secret_key_here

# Job search (optional — scripts work without this via free scraping)
RAPIDAPI_KEY=optional_for_enhanced_indeed_access

# Email (if using Gmail automation)
GMAIL_CREDENTIALS_FILE=path/to/gmail_credentials.json
