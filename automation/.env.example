# WordPress Automation System — sourovdeb.com
# Copy this to .env and fill in values — NEVER commit .env to git
# This file (.env.example) is safe to commit — no real secrets here

WP_SITE=https://sourovdeb.com
WP_API_KEY=your_api_key_here
WP_DEPLOY_URL=https://www.sourovdeb.com/deploy.php
WP_DEPLOY_KEY=your_deploy_key_here
WP_FTP_HOST=ftp.sourovdeb.com
WP_FTP_USER=your_ftp_user_here
WP_FTP_PASS=your_ftp_password_here
WP_FTP_PORT=21
