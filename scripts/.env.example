# Copy this file to scripts/.env and fill in your values.
# The .env file is in .gitignore — it will NEVER be committed.

# WordPress REST API endpoint (your custom plugin endpoint)
WP_API_URL=https://yourdomain.com/wp-json/sourov/v1/ai-post

# API key sent in X-Sourov-Key header
WP_API_KEY=your-api-key-here

# Base URL used by the health checker
WP_BASE_URL=https://yourdomain.com

# Folder watched by auto_publisher.py and folder_watcher.js
WP_WATCH_DIR=/home/yourname/wordpress_queue

# Default post status: draft | publish | future
WP_POST_STATUS=draft

# ── Email (job_hunter.py) ────────────────────────────────────────────
EMAIL_FROM=your_address@zohomail.com
EMAIL_TO=destination@example.com
EMAIL_PASSWORD=your-app-password
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
